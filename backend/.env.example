# Dropbox OAuth credentials
DROPBOX_APP_KEY=your_app_key
DROPBOX_APP_SECRET=your_app_secret
DROPBOX_REFRESH_TOKEN=your_refresh_token

# Root Dropbox folder to index (do NOT include trailing slash)
DROPBOX_ROOT_PATH=/Creative 2026/Video Assets

# Anthropic (Claude) for AI tag suggestions
ANTHROPIC_API_KEY=your_anthropic_api_key

# Optional: password-protect the admin panel
ADMIN_PASSWORD=

# Server port
PORT=3001

# SQLite DB path
DB_PATH=./asset_library.db
